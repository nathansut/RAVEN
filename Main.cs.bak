        // This built to handle saving images from recog 
        // Verify write from recog (know that we've written)
        // Verify windows file deleted to overwrite (if exists)
        // Verify recog file written to prev file
        // 5 ms slower than suggested GPT but I like more saving at the very end.
        private static bool RecogSaveTif(int ImgHandle, string _tif)
        {
            string TmpFile = _tif.Replace(".tif", ".tmp");

            // Delete tmp file if exists
            File.Delete(TmpFile); 
            if (VerifyDelete(TmpFile) == false)
            {
                MessageBox.Show("Unable to delete temp file!");
                return false;
            }

            try
            {
                // Attempt to save the image
                RecoIP.ImgSaveAsTif(ImgHandle, TmpFile, 5, 0);
            }
            catch (System.Runtime.InteropServices.SEHException)
            {
                // Wait for 1 second and retry once
                System.Threading.Thread.Sleep(1000);
                try
                {
                    RecoIP.ImgSaveAsTif(ImgHandle, TmpFile, 5, 0);
                }
                catch (System.Runtime.InteropServices.SEHException ex)
                {
                    MessageBox.Show("Failed to save image after retry: " + ex.Message);
                    return false;
                }
            }

            // Verify file saved as .tmp file
            if (!File.Exists(TmpFile))
            {
                MessageBox.Show("Unable to save file to temp file!");
                return false; 
            }

            File.Delete(_tif); 
            // Verify we were able to delete existing TIF file
            if (File.Exists(_tif))
            {
                MessageBox.Show("Unable to delete existing TIF file!");
                return false; 
            }

            File.Move(TmpFile, _tif);
            // Verify file was moved
            if (!File.Exists(_tif))
            {
                MessageBox.Show("Unable to overwrite TIF file with Temp file!");
                return false;
            }

            File.Delete(TmpFile); // Not too worried if it isn't deleted but would prefer for it to be. 
            return true; 
        }

        private static bool RecogSaveJPG(int ImgHandle, string _jpg)
        {
            // Eventually merge this into RecogSaveJPGTIF(ImgHandle, _file, JPG/TIF)

            string TmpFile = _jpg.Replace(".jpg", ".tmp").Replace(".jpeg", ".tmp");
            

            // Delete tmp file if exists
            File.Delete(TmpFile);
            if (VerifyDelete(TmpFile) == false)
            {
                MessageBox.Show("Unable to delete temp file!");
                return false;
            }

            RecoIP.ImgSaveAsJpg(ImgHandle, TmpFile, 80); 

            // Verify file saved as .tmp file
            if (!File.Exists(TmpFile))
            {
                MessageBox.Show("Unable to save file to temp file!");
                return false;
            }

            File.Delete(_jpg);
            // Verify we were able to delete existing TIF file
            if (File.Exists(_jpg))
            {
                MessageBox.Show("Unable to delete existing JPG file!");
                return false;
            }

            File.Move(TmpFile, _jpg);
            // Verify file was moved
            if (!File.Exists(_jpg))
            {
                MessageBox.Show("Unable to overwrite JPG file with Temp file!");
                return false;
            }
            File.Delete(TmpFile); // Not too worried if it isn't deleted but would prefer for it to be. 
            return true;
        }

        private static bool VerifyDelete(string _file)
        {
            if (File.Exists(_file))
            {
                try
                {
                    File.Delete(_file);
                }
                catch (IOException)
                {
                    // Log or handle the error as needed
                    MessageBox.Show("Unable to delete file!");
                    return false;
                }
            }

            return true;
        }




